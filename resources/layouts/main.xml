<?xml version="1.0" encoding="UTF-8"?>
<!-- NUI: Example launcher layout -->
<!-- This file defines the UI structure in XML, similar to xrUICore's UI XML files. -->
<layout name="launcher" x="0" y="0" width="1024" height="768" bg_color="20,20,30">

    <!-- Header bar -->
    <panel name="header" x="0" y="0" width="1024" height="60" bg_color="35,35,50">
        <label name="title" x="20" y="10" width="400" height="40"
               text="NUI Launcher" font_size="24" text_color="200,200,255"/>
        <label name="version" x="800" y="20" width="200" height="30"
               text="v0.1.0" font_size="14" text_color="120,120,140" align_h="right"/>
    </panel>

    <!-- Sidebar -->
    <panel name="sidebar" x="0" y="60" width="250" height="708" bg_color="28,28,42">
        <button name="btn_play" x="20" y="20" width="210" height="50"
                text="PLAY" font_size="20"
                bg_color="40,120,40" hover_color="50,150,50" pressed_color="30,100,30"/>
        <button name="btn_settings" x="20" y="80" width="210" height="40"
                text="Settings" font_size="16"/>
        <button name="btn_exit" x="20" y="130" width="210" height="40"
                text="Exit" font_size="16"
                bg_color="120,40,40" hover_color="150,50,50" pressed_color="100,30,30"/>
        <label x="20" y="200" width="210" height="20"
               text="Download Progress:" font_size="12" text_color="150,150,170"/>
        <progressbar name="progress" x="20" y="225" width="210" height="25"
                     value="0.65" show_percent="true"
                     fill_color="40,120,200" border_color="80,80,100"/>
        <editbox name="search" x="20" y="280" width="210" height="32"
                 placeholder="Search..." font_size="14"/>
    </panel>

    <!-- Content area -->
    <panel name="content" x="250" y="60" width="774" height="708" bg_color="24,24,34">
        <image name="cover" x="20" y="20" width="400" height="250"
               src="resources/images/cover.png" scale="fit"/>
        <label x="440" y="20" width="310" height="35"
               text="Game Title" font_size="28" text_color="220,220,255"/>
        <label x="440" y="60" width="310" height="200"
               text="This is a demo of the NUI, a lightweight CPU-only cross-platform UI toolkit designed for game launchers."
               font_size="14" text_color="180,180,190" word_wrap="true"/>
        <label x="20" y="290" width="200" height="25"
               text="Recent News:" font_size="18" text_color="200,200,220"/>
        <scrollview name="news_scroll" x="20" y="320" width="734" height="360"
                    border_color="60,60,80">
            <panel x="10" y="10" width="710" height="50" bg_color="35,35,50" border_color="50,50,65">
                <label x="10" y="5" width="690" height="20"
                       text="Update 1.2.3 - New features added" font_size="14" text_color="200,200,220"/>
                <label x="10" y="28" width="690" height="15"
                       text="2026-07-03" font_size="11" text_color="100,100,120"/>
            </panel>
            <panel x="10" y="65" width="710" height="50" bg_color="35,35,50" border_color="50,50,65">
                <label x="10" y="5" width="690" height="20"
                       text="Server maintenance scheduled" font_size="14" text_color="200,200,220"/>
                <label x="10" y="28" width="690" height="15"
                       text="2026-07-02" font_size="11" text_color="100,100,120"/>
            </panel>
            <panel x="10" y="120" width="710" height="50" bg_color="35,35,50" border_color="50,50,65">
                <label x="10" y="5" width="690" height="20"
                       text="New game mode coming soon!" font_size="14" text_color="200,200,220"/>
                <label x="10" y="28" width="690" height="15"
                       text="2026-07-01" font_size="11" text_color="100,100,120"/>
            </panel>
        </scrollview>
    </panel>

</layout>
